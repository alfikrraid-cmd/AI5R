{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI5R Module Spec Schema",
  "version": "0.1.0",
  "type": "object",
  "required": ["module", "resource", "database", "endpoint", "operation"],
  "properties": {
    "module": { "type": "string" },
    "resource": { "type": "string" },
    "operation": {
      "type": "string",
      "enum": ["list", "detail", "create", "update", "delete"]
    },
    "endpoint": {
      "type": "object",
      "required": ["method", "path"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
        },
        "path": { "type": "string" }
      }
    },
    "database": {
      "type": "object",
      "required": ["table"],
      "properties": {
        "table": { "type": "string" },
        "primary_key": { "type": "string" },
        "query_param": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
